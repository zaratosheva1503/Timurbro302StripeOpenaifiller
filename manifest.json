{
  "manifest_version": 3,
  "name": "Zarif Card Automation",
  "version": "6.3.4",
  "description": "Automatically fill payment checkout with generated cards",
  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "activeTab",
    "sidePanel",
    "cookies"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://checkout.stripe.com/*",
        "https://pay.openai.com/*",
        "https://chatgpt.com/*",
        "https://js.stripe.com/*",
        "https://payments.google.com/*",
        "https://pay.google.com/*",
        "https://em.bjedu.tech/*",
        "https://auth.openai.com/*"
      ],
      "all_frames": true,
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "images/zarif card auto logo.png",
    "32": "images/zarif card auto logo.png",
    "48": "images/zarif card auto logo.png",
    "128": "images/zarif card auto logo.png"
  },
  "action": {
    "default_title": "Zarif Card Automation",
    "default_icon": {
      "16": "images/zarif card auto logo.png",
      "32": "images/zarif card auto logo.png",
      "48": "images/zarif card auto logo.png",
      "128": "images/zarif card auto logo.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  }
}