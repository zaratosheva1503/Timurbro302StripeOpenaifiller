{
  "manifest_version": 3,
  "name": "Timurbro302 Card Automation",
  "version": "6.6.3",
  "description": "Automatically fill payment checkout with generated cards",
  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "activeTab",
    "sidePanel",
    "cookies",
    "debugger"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "all_frames": true,
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "images/zarif card auto logo.png",
    "32": "images/zarif card auto logo.png",
    "48": "images/zarif card auto logo.png",
    "128": "images/zarif card auto logo.png"
  },
  "action": {
    "default_title": "Timurbro302 Card Automation",
    "default_icon": {
      "16": "images/zarif card auto logo.png",
      "32": "images/zarif card auto logo.png",
      "48": "images/zarif card auto logo.png",
      "128": "images/zarif card auto logo.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "incognito": "spanning"
}